# AI Embeddings
DASHSCOPE_API_KEY=sk-7008870c0a094729899a1a2edb75da4d
# Embedding模型选择: "dashscope" 使用云端API(慢,~42s), "local" 使用本地中文模型(快,~1-2s)
EMBEDDING_MODEL=local
# 本地Embedding模型（默认BAAI/bge-small-zh-v1.5，首次使用需下载约90MB）
LOCAL_EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
# Milvus Configuration
MILVUS_HOST=192.168.150.105
MILVUS_PORT=19530

# Redis Configuration
REDIS_HOST=192.168.150.106
REDIS_PORT=6379
REDIS_PASSWORD=your_strong_password

# Optional: Milvus Authentication (if enabled)
# MILVUS_USER=username
# MILVUS_PASSWORD=password

# Vector Store Selection (true for Milvus, false for FAISS)
USE_MILVUS=false
# Vector Store Configuration
VECTOR_STORE_PERSIST_DIR=./faiss_index
VECTOR_STORE_COLLECTION_NAME=ai_knowledge_collection

# Rerank Configuration
# Rerank type: 'bge' (recommended, local), 'cohere' (requires API key), 'simple' (fallback), 'none' (disabled)
RERANKER_TYPE=simple

# Optional: Cohere API Key (if using Cohere reranker)
# COHERE_API_KEY=your_cohere_api_key

# Text Chunking Configuration
# Chunk strategy: 'semantic' (recommended), 'recursive' (default)
CHUNK_STRATEGY=semantic
CHUNK_SIZE=500
CHUNK_OVERLAP=50
MIN_CHUNK_SIZE=100

# Tesseract OCR Configuration
# Tesseract executable path
TESSERACT_PATH=E:/Tesseract-OCR/tesseract.exe

# Temporary Files Configuration
TEMP_DIR=./temp

# Logging Configuration
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# API Configuration
API_HOST=0.0.0.0
API_PORT=8080

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
